generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  LIBRARIAN
}

enum AuthorStatus {
  ACTIVE
  DISABLED
}

enum CooperationLevel {
  A
  B
  C
  D
}

model User {
  id                      Int                      @id @default(autoincrement())
  username                String                   @unique
  password                String
  role                    Role                     @default(LIBRARIAN)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  waivedFines             Fine[]                   @relation("WaivedFines")
  finePayments            FinePayment[]
  reservationStatusLogs   ReservationStatusLog[]
  officialReplyReviews    BookReview[]
  seatReservationOps      SeatReservation[]
  announcements           Announcement[]
  createdStockTakes       StockTake[]              @relation("StockTakeCreator")
  reviewedStockTakes      StockTake[]              @relation("StockTakeReviewer")
  countedStockTakeItems   StockTakeItem[]
  stockTakeStatusLogs     StockTakeStatusLog[]
  createdDonations        Donation[]               @relation("DonationCreator")
  reviewedDonations       Donation[]               @relation("DonationReviewer")
  stockedDonations        Donation[]               @relation("DonationStocker")
  donationStatusLogs      DonationStatusLog[]
}

model Borrower {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  phone            String?
  email            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  borrows          BorrowRecord[]
  fines            Fine[]
  reviews          BookReview[]
  reservations     Reservation[]
  seatReservations SeatReservation[]
}

model Category {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  books         Book[]
  stockTakes    StockTake[]
  donationBooks DonationBook[]
}

model Publisher {
  id               Int              @id @default(autoincrement())
  name             String           @unique
  location         String?
  postalCode       String?
  phone            String?
  website          String?
  cooperationLevel CooperationLevel @default(B)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  books            Book[]

  @@index([cooperationLevel])
}

model Author {
  id             Int            @id @default(autoincrement())
  name           String
  nationality    String?
  birthYear      Int?
  deathYear      Int?
  biography      String?
  representativeWorks String?
  pinyinInitial  String?
  status         AuthorStatus   @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  bookAuthors    BookAuthor[]

  @@unique([name, birthYear])
  @@index([pinyinInitial])
  @@index([nationality])
  @@index([status])
}

model BookAuthor {
  bookId      Int
  authorId    Int
  book        Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author      Author @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())

  @@id([bookId, authorId])
  @@index([authorId])
}

model BookReview {
  id                Int        @id @default(autoincrement())
  bookId            Int
  book              Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  borrowerId        Int
  borrower          Borrower   @relation(fields: [borrowerId], references: [id])
  borrowRecordId    Int        @unique
  borrowRecord      BorrowRecord @relation("BorrowRecordReview", fields: [borrowRecordId], references: [id])
  rating            Int
  comment           String?
  isComplaint       Boolean    @default(false)
  officialReply     String?
  officialReplyAt   DateTime?
  officialReplyById Int?
  officialReplyBy   User?      @relation(fields: [officialReplyById], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([bookId])
  @@index([rating])
  @@index([createdAt])
}

model Tag {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  color       String    @default("#409eff")
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookTags    BookTag[]
}

model BookTag {
  bookId    Int
  tagId     Int
  book      Book   @relation(fields: [bookId], references: [id])
  tag       Tag    @relation(fields: [tagId], references: [id])
  createdAt DateTime @default(now())

  @@id([bookId, tagId])
  @@index([tagId])
}

model Book {
  id          Int        @id @default(autoincrement())
  title       String
  author      String
  isbn        String     @unique
  stock       Int        @default(0)
  price       Float
  description String?
  categoryId  Int
  category    Category   @relation(fields: [categoryId], references: [id])
  publisherId Int?
  publisher   Publisher? @relation(fields: [publisherId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  borrows          BorrowRecord[]
  bookTags         BookTag[]
  bookAuthors      BookAuthor[]
  reviews          BookReview[]
  reservations     Reservation[]
  stockTakeItems   StockTakeItem[]
  donationBooks    DonationBook[]
}

model BorrowRecord {
  id         Int          @id @default(autoincrement())
  bookId     Int
  book       Book         @relation(fields: [bookId], references: [id])
  borrowerId Int
  borrower   Borrower     @relation(fields: [borrowerId], references: [id])
  borrowDate DateTime     @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     String       @default("BORROWED") // BORROWED, RETURNED
  fines      Fine[]
  review     BookReview?  @relation("BorrowRecordReview")
}

enum ReservationStatus {
  PENDING
  PENDING_PICKUP
  COMPLETED
  CANCELLED
  EXPIRED
}

model Reservation {
  id          Int                @id @default(autoincrement())
  bookId      Int
  book        Book               @relation(fields: [bookId], references: [id])
  borrowerId  Int
  borrower    Borrower           @relation(fields: [borrowerId], references: [id])
  status      ReservationStatus  @default(PENDING)
  queueNumber Int
  createdAt   DateTime           @default(now())
  expiresAt   DateTime?
  pickedUpAt  DateTime?
  cancelledAt DateTime?
  statusLogs  ReservationStatusLog[]
}

model ReservationStatusLog {
  id            Int                @id @default(autoincrement())
  reservationId Int
  reservation   Reservation        @relation(fields: [reservationId], references: [id])
  fromStatus    ReservationStatus?
  toStatus      ReservationStatus
  operatorId    Int?
  operator      User?              @relation(fields: [operatorId], references: [id])
  remark        String?
  createdAt     DateTime           @default(now())
}

enum FineStatus {
  PENDING
  PARTIAL
  PAID
  WAIVED
}

model Fine {
  id             Int          @id @default(autoincrement())
  borrowRecordId Int
  borrowRecord   BorrowRecord @relation(fields: [borrowRecordId], references: [id])
  borrowerId     Int
  borrower       Borrower     @relation(fields: [borrowerId], references: [id])
  totalAmount    Float        @default(0)
  paidAmount     Float        @default(0)
  waivedAmount   Float        @default(0)
  overdueDays    Int          @default(0)
  dailyRate      Float        @default(0)
  graceDays      Int          @default(0)
  status         FineStatus   @default(PENDING)
  lastCalculated DateTime?
  receiptNo      String?
  waiveRemark    String?
  waiveOperatorId Int?
  waiveOperator  User?        @relation("WaivedFines", fields: [waiveOperatorId], references: [id])
  payments       FinePayment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model FinePayment {
  id         Int      @id @default(autoincrement())
  fineId     Int
  fine       Fine     @relation(fields: [fineId], references: [id])
  amount     Float
  receiptNo  String?
  operatorId Int?
  operator   User?    @relation(fields: [operatorId], references: [id])
  remark     String?
  createdAt  DateTime @default(now())
}

model SystemSettings {
  id             Int      @id @default(autoincrement())
  key            String   @unique
  value          String
  description    String?
  updatedAt      DateTime @updatedAt
}

enum ZoneType {
  SILENT
  DISCUSSION
  GENERAL
  COMPUTER
}

model ReadingRoom {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  description String?
  location    String?
  openTime    String?
  closeTime   String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  zones       ReadingZone[]
}

model ReadingZone {
  id           Int      @id @default(autoincrement())
  name         String
  type         ZoneType @default(GENERAL)
  description  String?
  readingRoomId Int
  readingRoom  ReadingRoom @relation(fields: [readingRoomId], references: [id])
  seats        Seat[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([readingRoomId, name])
}

enum SeatStatus {
  AVAILABLE
  BANNED
}

model Seat {
  id           Int           @id @default(autoincrement())
  seatNumber   String
  zoneId       Int
  zone         ReadingZone   @relation(fields: [zoneId], references: [id])
  hasPowerOutlet Boolean     @default(false)
  isWindowSide Boolean      @default(false)
  status       SeatStatus    @default(AVAILABLE)
  banReason    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations SeatReservation[]

  @@unique([zoneId, seatNumber])
}

enum SeatReservationStatus {
  BOOKED
  CANCELLED
  CHECKED_IN
  NO_SHOW
  RELEASED
}

enum TimeSlot {
  MORNING_1
  MORNING_2
  AFTERNOON_1
  AFTERNOON_2
  EVENING_1
  EVENING_2
}

model SeatReservation {
  id         Int                     @id @default(autoincrement())
  seatId     Int
  seat       Seat                    @relation(fields: [seatId], references: [id])
  borrowerId Int
  borrower   Borrower                @relation(fields: [borrowerId], references: [id])
  date       DateTime
  timeSlot   TimeSlot
  status     SeatReservationStatus   @default(BOOKED)
  checkedInAt  DateTime?
  cancelledAt  DateTime?
  noShowAt     DateTime?
  releasedAt   DateTime?
  operatorId   Int?
  operator     User?                 @relation(fields: [operatorId], references: [id])
  remark       String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([seatId, date, timeSlot])
}

enum AnnouncementStatus {
  DRAFT
  PENDING
  PUBLISHED
  ARCHIVED
}

enum AnnouncementScope {
  ALL
  ADMIN
  LIBRARIAN
}

model Announcement {
  id          Int                @id @default(autoincrement())
  title       String
  summary     String?
  content     String
  contentType String?
  coverImage  String?
  scope       AnnouncementScope @default(ALL)
  status      AnnouncementStatus @default(DRAFT)
  isPinned    Boolean          @default(false)
  pinWeight   Int              @default(0)
  publishAt   DateTime?
  expireAt    DateTime?
  createdById Int?
  createdBy   User?              @relation(fields: [createdById], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([scope])
  @@index([isPinned])
  @@index([publishAt])
  @@index([expireAt])
}

enum StockTakeStatus {
  DRAFT
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
}

enum DiffReason {
  NORMAL
  LOST
  DAMAGED
  MISPLACED
  OTHER
}

model StockTake {
  id                Int              @id @default(autoincrement())
  title             String
  status            StockTakeStatus @default(DRAFT)
  totalBooks        Int              @default(0)
  totalExpectedQty  Int              @default(0)
  totalActualQty    Int              @default(0)
  totalDiffQty      Int              @default(0)
  totalDiffAmount   Float            @default(0)
  categoryId        Int?
  category          Category?        @relation(fields: [categoryId], references: [id])
  remark            String?
  createdById       Int?
  createdBy         User?            @relation("StockTakeCreator", fields: [createdById], references: [id])
  startedAt         DateTime?
  submittedAt       DateTime?
  reviewedById      Int?
  reviewedBy        User?            @relation("StockTakeReviewer", fields: [reviewedById], references: [id])
  reviewedAt        DateTime?
  completedAt       DateTime?
  items             StockTakeItem[]
  statusLogs        StockTakeStatusLog[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
}

model StockTakeItem {
  id             Int        @id @default(autoincrement())
  stockTakeId    Int
  stockTake      StockTake  @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  bookId         Int
  book           Book       @relation(fields: [bookId], references: [id])
  bookTitle      String
  bookIsbn       String
  bookPrice      Float
  expectedStock  Int
  actualStock    Int?
  diffQty        Int        @default(0)
  diffAmount     Float      @default(0)
  diffReason     DiffReason?
  locationRemark String?
  isCounted      Boolean    @default(false)
  countedById    Int?
  countedBy      User?      @relation(fields: [countedById], references: [id])
  countedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([stockTakeId])
  @@index([bookId])
  @@index([isCounted])
  @@unique([stockTakeId, bookId])
}

model StockTakeStatusLog {
  id          Int              @id @default(autoincrement())
  stockTakeId Int
  stockTake   StockTake        @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  fromStatus  StockTakeStatus?
  toStatus    StockTakeStatus
  operatorId  Int?
  operator    User?            @relation(fields: [operatorId], references: [id])
  remark      String?
  createdAt   DateTime         @default(now())

  @@index([stockTakeId])
  @@index([toStatus])
}

enum DonationStatus {
  PENDING
  APPROVED
  REJECTED
  PARTIAL_STOCKED
  STOCKED
}

enum BookCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum DonationChannel {
  INDIVIDUAL
  ORGANIZATION
  ONLINE
  EVENT
  OTHER
}

model Donation {
  id             Int              @id @default(autoincrement())
  donorName      String
  donorUnit      String?
  donorPhone     String?
  donorEmail     String?
  channel        DonationChannel  @default(INDIVIDUAL)
  status         DonationStatus   @default(PENDING)
  totalBooks     Int              @default(0)
  totalQty       Int              @default(0)
  totalValue     Float            @default(0)
  remark         String?
  createdById    Int?
  createdBy      User?            @relation("DonationCreator", fields: [createdById], references: [id])
  reviewedById   Int?
  reviewedBy     User?            @relation("DonationReviewer", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  reviewRemark   String?
  stockedById    Int?
  stockedBy      User?            @relation("DonationStocker", fields: [stockedById], references: [id])
  stockedAt      DateTime?
  items          DonationBook[]
  statusLogs     DonationStatusLog[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
  @@index([donorName])
  @@index([createdAt])
  @@index([channel])
}

model DonationBook {
  id            Int           @id @default(autoincrement())
  donationId    Int
  donation      Donation      @relation(fields: [donationId], references: [id], onDelete: Cascade)
  bookId        Int?
  book          Book?         @relation(fields: [bookId], references: [id])
  title         String
  isbn          String?
  quantity      Int           @default(1)
  condition     BookCondition @default(GOOD)
  estimatedValue Float        @default(0)
  donationDate  DateTime      @default(now())
  categoryId    Int?
  category      Category?     @relation(fields: [categoryId], references: [id])
  stockedQty    Int           @default(0)
  isStocked     Boolean       @default(false)
  remark        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([donationId])
  @@index([bookId])
  @@index([isbn])
  @@index([isStocked])
}

model DonationStatusLog {
  id          Int            @id @default(autoincrement())
  donationId  Int
  donation    Donation       @relation(fields: [donationId], references: [id], onDelete: Cascade)
  fromStatus  DonationStatus?
  toStatus    DonationStatus
  operatorId  Int?
  operator    User?          @relation(fields: [operatorId], references: [id])
  remark      String?
  createdAt   DateTime       @default(now())

  @@index([donationId])
  @@index([toStatus])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  LIBRARIAN
}

model User {
  id                      Int                      @id @default(autoincrement())
  username                String                   @unique
  password                String
  role                    Role                     @default(LIBRARIAN)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  waivedFines             Fine[]                   @relation("WaivedFines")
  finePayments            FinePayment[]
  reservationStatusLogs   ReservationStatusLog[]
}

model Borrower {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  borrows   BorrowRecord[]
  fines     Fine[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  books Book[]
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  isbn        String   @unique
  stock       Int      @default(0)
  price       Float
  description String?
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  borrows     BorrowRecord[]
}

model BorrowRecord {
  id         Int       @id @default(autoincrement())
  bookId     Int
  book       Book      @relation(fields: [bookId], references: [id])
  borrowerId Int
  borrower   Borrower  @relation(fields: [borrowerId], references: [id])
  borrowDate DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     String    @default("BORROWED") // BORROWED, RETURNED
  fines      Fine[]
}

enum ReservationStatus {
  PENDING
  PENDING_PICKUP
  COMPLETED
  CANCELLED
  EXPIRED
}

model Reservation {
  id          Int                @id @default(autoincrement())
  bookId      Int
  book        Book               @relation(fields: [bookId], references: [id])
  borrowerId  Int
  borrower    Borrower           @relation(fields: [borrowerId], references: [id])
  status      ReservationStatus  @default(PENDING)
  queueNumber Int
  createdAt   DateTime           @default(now())
  expiresAt   DateTime?
  pickedUpAt  DateTime?
  cancelledAt DateTime?
  statusLogs  ReservationStatusLog[]
}

model ReservationStatusLog {
  id            Int                @id @default(autoincrement())
  reservationId Int
  reservation   Reservation        @relation(fields: [reservationId], references: [id])
  fromStatus    ReservationStatus?
  toStatus      ReservationStatus
  operatorId    Int?
  operator      User?              @relation(fields: [operatorId], references: [id])
  remark        String?
  createdAt     DateTime           @default(now())
}

enum FineStatus {
  PENDING
  PARTIAL
  PAID
  WAIVED
}

model Fine {
  id             Int          @id @default(autoincrement())
  borrowRecordId Int
  borrowRecord   BorrowRecord @relation(fields: [borrowRecordId], references: [id])
  borrowerId     Int
  borrower       Borrower     @relation(fields: [borrowerId], references: [id])
  totalAmount    Float        @default(0)
  paidAmount     Float        @default(0)
  waivedAmount   Float        @default(0)
  overdueDays    Int          @default(0)
  dailyRate      Float        @default(0)
  graceDays      Int          @default(0)
  status         FineStatus   @default(PENDING)
  lastCalculated DateTime?
  receiptNo      String?
  waiveRemark    String?
  waiveOperatorId Int?
  waiveOperator  User?        @relation("WaivedFines", fields: [waiveOperatorId], references: [id])
  payments       FinePayment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model FinePayment {
  id         Int      @id @default(autoincrement())
  fineId     Int
  fine       Fine     @relation(fields: [fineId], references: [id])
  amount     Float
  receiptNo  String?
  operatorId Int?
  operator   User?    @relation(fields: [operatorId], references: [id])
  remark     String?
  createdAt  DateTime @default(now())
}

model SystemSettings {
  id             Int      @id @default(autoincrement())
  key            String   @unique
  value          String
  description    String?
  updatedAt      DateTime @updatedAt
}

enum ZoneType {
  SILENT
  DISCUSSION
  GENERAL
  COMPUTER
}

model ReadingRoom {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  description String?
  location    String?
  openTime    String?
  closeTime   String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  zones       ReadingZone[]
}

model ReadingZone {
  id           Int      @id @default(autoincrement())
  name         String
  type         ZoneType @default(GENERAL)
  description  String?
  readingRoomId Int
  readingRoom  ReadingRoom @relation(fields: [readingRoomId], references: [id])
  seats        Seat[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([readingRoomId, name])
}

enum SeatStatus {
  AVAILABLE
  BANNED
}

model Seat {
  id           Int           @id @default(autoincrement())
  seatNumber   String
  zoneId       Int
  zone         ReadingZone   @relation(fields: [zoneId], references: [id])
  hasPowerOutlet Boolean     @default(false)
  isWindowSide Boolean      @default(false)
  status       SeatStatus    @default(AVAILABLE)
  banReason    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations SeatReservation[]

  @@unique([zoneId, seatNumber])
}

enum SeatReservationStatus {
  BOOKED
  CANCELLED
  CHECKED_IN
  NO_SHOW
  RELEASED
}

enum TimeSlot {
  MORNING_1
  MORNING_2
  AFTERNOON_1
  AFTERNOON_2
  EVENING_1
  EVENING_2
}

model SeatReservation {
  id         Int                     @id @default(autoincrement())
  seatId     Int
  seat       Seat                    @relation(fields: [seatId], references: [id])
  borrowerId Int
  borrower   Borrower                @relation(fields: [borrowerId], references: [id])
  date       DateTime
  timeSlot   TimeSlot
  status     SeatReservationStatus   @default(BOOKED)
  checkedInAt  DateTime?
  cancelledAt  DateTime?
  noShowAt     DateTime?
  releasedAt   DateTime?
  operatorId   Int?
  operator     User?                 @relation(fields: [operatorId], references: [id])
  remark       String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([seatId, date, timeSlot])
}
